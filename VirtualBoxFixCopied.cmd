@echo off
setlocal EnableExtensions DisableDelayedExpansion
chcp 65001 >nul 2>&1

set "VM_DIR=%~dp0"
if "%VM_DIR:~-1%"=="\" set "VM_DIR=%VM_DIR:~0,-1%"
set "SCRIPT_PATH=%~f0"
set "LOG_FILE=%VM_DIR%\fix_virtualbox_vm.log"
set "VBOXMANAGE=C:\Program Files\Oracle\VirtualBox\VBoxManage.exe"

echo ==================================================
echo VirtualBox copied VM fixer v5
echo Started: %date% %time%
echo Script : %SCRIPT_PATH%
echo VM dir : %VM_DIR%
echo ==================================================

> "%LOG_FILE%" (
  echo ==================================================
  echo VirtualBox copied VM fixer v5
  echo Started: %date% %time%
  echo Script : %SCRIPT_PATH%
  echo VM dir : %VM_DIR%
  echo ==================================================
)

if not exist "%VBOXMANAGE%" (
  echo ERROR: VBoxManage not found at "%VBOXMANAGE%"
  >> "%LOG_FILE%" echo ERROR: VBoxManage not found at "%VBOXMANAGE%"
  pause
  exit /b 1
)

set /p "NEW_VM_NAME=Enter new VM name: "
if not defined NEW_VM_NAME (
  echo ERROR: New VM name cannot be empty.
  >> "%LOG_FILE%" echo ERROR: New VM name cannot be empty.
  pause
  exit /b 1
)

echo Running repair...
>> "%LOG_FILE%" echo Running repair...

powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
set "RC=%ERRORLEVEL%"

echo.
echo Finished with exit code %RC% at %date% %time%
>> "%LOG_FILE%" echo Finished with exit code %RC% at %date% %time%

if not "%RC%"=="0" (
  echo.
  echo [ERROR] Script failed. See log:
  echo   %LOG_FILE%
) else (
  echo.
  echo [OK] Script completed. Log:
  echo   %LOG_FILE%
)

pause
exit /b %RC%
